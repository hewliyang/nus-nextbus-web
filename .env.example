# ─────────────────────────────────────────────────────────────────────────────
# nus-livebus configuration
#
# This app reads live shuttle timings from hewliyang's public deployment
# (https://bus.hewliyang.com) instead of NUS's credentialed FMS backend, so it
# needs NO secrets to run. The single optional variable below lets you point at
# a different / self-hosted upstream.
# ─────────────────────────────────────────────────────────────────────────────

# OPTIONAL: upstream base URL for the shuttle data source.
# Defaults to https://bus.hewliyang.com when unset.
# HEWLIYANG_BASE="https://bus.hewliyang.com"
